  <title>Studio — Green Street Studio</title>
  <meta name="description" content="Green Street Studio offers private piano instruction in downtown Princeton with Raisa Ihnat, Steinway & Sons STEP Certified Teacher." />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" referrerpolicy="no-referrer" />

  <style>
    :root{
      --bg:#000;
      --ink:#e6f0ff;
      --pad:clamp(14px,2.5vw,24px);
      --max:900px;
      --radius:14px;
      --border:#e5e5ef;
      --muted:#555;
      --accent:#2d4a2b;
      --accent-dark:#000;
    }

    *{ box-sizing:border-box; }
    body{
      margin:0; background:var(--bg); color: #000;
      font-family:"Lora", Georgia, serif; min-height:100vh; display:flex; flex-direction:column;
    }

    /* Top nav */
    header{ position:sticky; top:0; background:#000; border-bottom:0.5px solid #eee; z-index: 10; }
    .nav{
      max-width:var(--max); margin:0 auto; padding:var(--pad);
      display:flex; align-items:center; gap:24px; justify-content:center;
      font-family:"Lora", Georgia, serif; font-weight:900;
    }
    .nav a{ color:var(--ink); text-decoration:none; letter-spacing:.06em; }
    .nav a:hover{ text-decoration:underline; }

    main{ flex:1; max-width:var(--max); margin:0 auto; padding:var(--pad); }

    /* ============================================================
       STUDIO HERO
       ============================================================ */
    .studio-hero{
      text-align:center;
      padding: clamp(20px, 4vw, 40px) 0 clamp(24px, 4vw, 40px);
      border-bottom: 1px solid var(--border);
      margin-bottom: clamp(24px, 4vw, 40px);
    }
    .studio-eyebrow{
      display:inline-block;
      font-size:.75rem;
      letter-spacing:.18em;
      text-transform:uppercase;
      color:var(--muted);
      margin-bottom:.85rem;
      font-weight:400;
    }
    .studio-title{
      font-family:"Lora", Georgia, serif;
      font-weight:900;
      font-size: clamp(28px, 4.5vw, 42px);
      margin:0 0 .8rem;
      line-height:1.1;
      color: var(--accent);
      letter-spacing: .03em;
    }
    .studio-subtitle{
      font-style: italic;
      color: #000;
      font-size: clamp(15px, 2vw, 18px);
      margin: 0 0 1.25rem;
    }
    .studio-lede{
      color:#000;
      margin: 0 auto;
      max-width: 56ch;
      font-size:1rem;
      line-height:1.7;
    }

    /* Credential pill */
    .credential-pill{
      display: inline-block;
      margin-top: 1.5rem;
      padding: 10px 18px;
      background: #fafafe;
      border: 1px solid var(--border);
      border-radius: 999px;
      font-size: .85rem;
      letter-spacing: .04em;
      color: var(--accent-dark);
      font-style: italic;
    }
    .credential-pill strong{
      font-weight: 700;
      font-style: normal;
      letter-spacing: .06em;
      color: var(--accent);
    }

    /* ============================================================
       CALENDAR LINK SECTION
       ============================================================ */
    .info-block{
      background:#fff;
      border:1px solid var(--border);
      border-radius: var(--radius);
      padding: clamp(20px, 3vw, 32px);
      margin-bottom: clamp(20px, 3vw, 28px);
      box-shadow:0 4px 12px rgba(0,0,0,.04);
    }
    .info-block__heading{
      font-family:"Lora", Georgia, serif;
      font-weight:900;
      font-size: 1.2rem;
      color: var(--accent);
      margin: 0 0 1rem;
      letter-spacing: .03em;
    }
    .info-block p{
      margin: 0 0 1rem;
      line-height: 1.65;
      font-size: .98rem;
    }
    .info-block p:last-child{ margin-bottom: 0; }

    .calendar-link-row{
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      padding: 14px 18px;
      background: #fafafe;
      border: 1px solid var(--border);
      border-radius: 10px;
    }
    .calendar-link-row__text{
      font-size: .95rem;
      color: #000;
    }
    .calendar-link-row__text strong{
      font-weight: 700;
      color: var(--accent);
    }
    .calendar-link{
      display: inline-block;
      padding: 10px 18px;
      background: var(--accent);
      color: #fff;
      text-decoration: none;
      border-radius: 8px;
      font-size: .9rem;
      letter-spacing: .04em;
      font-weight: 700;
      transition: opacity .2s ease;
    }
    .calendar-link:hover{ opacity: .85; }

    /* ============================================================
       INQUIRY FORM
       ============================================================ */
    .form-section{
      background:#fff;
      border:1px solid var(--border);
      border-radius: var(--radius);
      padding: clamp(20px, 3vw, 32px);
      margin-bottom: clamp(24px, 4vw, 40px);
      box-shadow:0 4px 12px rgba(0,0,0,.04);
    }
    .form-section h2{
      margin:0 0 .4rem; font-family:"Lora", Georgia, serif; font-weight:900;font-size:1.2rem;
      color: var(--accent);
      letter-spacing: .03em;
    }
    .form-section .small{ color:var(--muted); margin:0 0 1.25rem; font-size:.95rem; }

    form.contact-form{ display:flex; flex-direction:column; gap:14px; }
    label{ font-weight:400; font-size:.95rem; }
    input, textarea, select{
      width:100%; padding:12px; border:1px solid var(--border); border-radius:10px; font:inherit; background:#fafafe;
    }
    textarea {
      min-height: 140px;
      resize: vertical;
    }

    .row {
      display: grid;
      gap: 14px;
      grid-template-columns: 1fr 1fr;
    }
    @media (max-width: 560px) {
      .row { grid-template-columns: 1fr; }
    }

    .actions{ display:flex; gap:12px; align-items:center; justify-content:center; flex-wrap:wrap; margin-top: .25rem; }

    .btn {
      display: inline-block;
      padding: 12px 18px;
      border-radius: 10px;
      border: 1px solid #000;
      background: #000;
      color: #ffffff;
      font-weight: 700;
      letter-spacing: .04em;
      cursor: pointer;
      transition: color 0.25s ease, background 0.25s ease;
    }
    .btn:hover { color: #1a8cff; }

    .email-btn {
      display:flex;
      align-items:center;
      justify-content:center;
      width:48px;
      height:48px;
      border-radius:10px;
      font-size:20px;
      padding:0;
      border:1px solid #000;
      background:#fff;
      color:#000;
      transition:transform .2s ease, background .2s ease, color .2s ease;
    }
    .email-btn:hover {
      background:#000;
      color:#fff;
      transform:scale(1.1);
    }

    .success, .error{
      display:none; margin-top:8px; padding:10px 12px; border-radius:10px; font-weight:400; text-align:center;
    }
    .success{ background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; }
    .error{ background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }

    /* ============================================================
       FAQ & STUDIO POLICIES
       ============================================================ */
    .lessons-info{
      background:#fff;
      border:1px solid var(--border);
      border-radius: var(--radius);
      padding: clamp(22px, 3.5vw, 40px) clamp(18px, 3vw, 36px);
      box-shadow:0 4px 12px rgba(0,0,0,.04);
      color:#000;
      font-family:"Lora", Georgia, serif;
      font-weight:400;
      line-height:1.6;
      margin-bottom: clamp(24px, 4vw, 48px);
    }
    .lessons-info__intro{
      text-align:center;
      padding-bottom: 1.5rem;
      margin-bottom: 1.5rem;
      border-bottom:1px solid var(--border);
    }
    .lessons-info__title{
      font-family:"Lora", Georgia, serif;
      font-weight:900;
      font-size: clamp(20px, 2.8vw, 24px);
      margin:0 0 .6rem;
      line-height:1.2;
      color: var(--accent);
    }
    .lessons-info__lede{
      color:#000;
      margin: 0 auto;
      max-width: 56ch;
      font-size:.95rem;
    }
    .lessons-info__section-heading{
      font-family:"Lora", Georgia, serif;
      font-weight:900;
      font-size: 1.1rem;
      margin: 1.75rem 0 .25rem;
      padding-bottom:.5rem;
      border-bottom:1px solid var(--border);
      text-align:center;
      letter-spacing:.04em;
      color: var(--accent);
    }
    .lessons-info__section-heading:first-of-type{ margin-top: 0.5rem; }
    .lessons-info details{
      border-bottom:1px solid var(--border);
    }
    .lessons-info details:last-of-type{
      border-bottom:none;
    }
    .lessons-info summary{
      cursor:pointer;
      list-style:none;
      padding: 1rem 2.25rem 1rem .25rem;
      position:relative;
      font-family:"Lora", Georgia, serif;
      font-weight:400;
      font-size: 1rem;
      color:#000;
      transition: color .2s ease;
      user-select:none;
    }
    .lessons-info summary:hover{ color:var(--accent); }
    .lessons-info summary:focus-visible{
      outline:2px solid var(--accent);
      outline-offset:2px;
      border-radius:4px;
    }
    .lessons-info summary::-webkit-details-marker{ display:none; }
    .lessons-info summary::marker{ content:""; }
    .lessons-info summary::after{
      content:"+";
      position:absolute;
      right:.4rem;
      top:50%;
      transform:translateY(-50%);
      font-family:"Lora", Georgia, serif;
      font-weight:400;
      font-size:1.4rem;
      color:#000;
      transition: color .2s ease;
      line-height:1;
    }
    .lessons-info summary:hover::after{ color:var(--accent); }
    .lessons-info details[open] summary::after{ content:"\2013"; }
    .lessons-info details > div{
      padding: .25rem .25rem 1.25rem;
      color:#000;
      font-size: .96rem;
      animation: liFade .25s ease;
    }
    .lessons-info details p{ margin: 0 0 .8rem; font-weight:400; }
    .lessons-info details p:last-child{ margin-bottom:0; }
    .lessons-info details ul{
      margin: .35rem 0 .8rem;
      padding-left: 1.2rem;
    }
    .lessons-info details li{ margin-bottom: .35rem; font-weight:400; }
    @keyframes liFade{
      from { opacity:0; transform: translateY(-3px); }
      to   { opacity:1; transform: translateY(0); }
    }
    .lessons-info__footnote{
      margin: 2rem 0 0;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      text-align:center;
      color:var(--muted);
      font-size:.88rem;
      font-style:italic;
    }
    @media (max-width: 560px){
      .lessons-info summary{ font-size:.97rem; padding-right: 2rem; }
    }

    footer{ text-align:center; padding:2rem; color: var(--ink); }
  </style>
</head>
